{
    "include": ["./src"],
    "compilerOptions": {
        "lib": [
            "ES2024"
        ],
        "target": "ES2022",
        "module": "Node20",
        "moduleResolution": "Node16",
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "rootDir": "./src",
        "outDir": "./dist",
        "declaration": true,
        "types": ["@types/node"],
    }
}
