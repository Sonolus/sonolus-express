    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0"
  },
  "peerDependencies": {
    "@sonolus/core": "~7.15.3",
    "express": "^4.22.2",
    "multer": "^2.2.0",
    "typebox": "^1.3.7"
